{
  "name": "excalidraw-cli",
  "version": "0.1.0",
  "description": "Export Excalidraw files to PNG or SVG from the command line",
  "type": "module",
  "bin": {
    "excalidraw-cli": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "lint": "eslint src tests",
    "format": "prettier --write src tests",
    "prepare": "husky",
    "prepublishOnly": "npm run build && npm test"
  },
  "dependencies": {
    "@excalidraw/excalidraw": "^0.17.6",
    "@resvg/resvg-js": "^2.6.0",
    "commander": "^14.0.3",
    "glob": "^13.0.6",
    "jsdom": "^28.1.0"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@types/jsdom": "^28.0.0",
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^4.1.0",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.3",
    "prettier": "^3.8.1",
    "tsup": "^8.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.57.0",
    "vitest": "^4.1.0"
  }
}
